{
  "manifest_version": 3,
  "name": "Clawmander Snitch",
  "version": "1.3.0",
  "description": "The strategic eye of your earning swarm. 1970s analog-grade surveillance and project management interface.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "icons": {
    "128": "assets/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Clawmander Snitch",
    "default_icon": "assets/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["gifs/*", "assets/*", "companion.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
